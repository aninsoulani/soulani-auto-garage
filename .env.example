# =============================================
# BACKEND (apps/api/.env)
# =============================================
# Node Environment (development | production)
# NOTE: Rate limits are multiplied by 100x when NOT in production to prevent local testing lockouts.
NODE_ENV="development"

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/soulani_db"
JWT_SECRET="min_64_char_secret"
JWT_REFRESH_SECRET="min_64_char_refresh_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Default Admin Credentials for DB Seeding
DEFAULT_ADMIN_EMAIL="admin@soulanigarage.com"
DEFAULT_ADMIN_PASSWORD="SecretPassword123"

PORT=3001
FRONTEND_URL="http://localhost:3000"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================
# FRONTEND (apps/web/.env.local)
# =============================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_WHATSAPP_NUMBER=6281122334455
